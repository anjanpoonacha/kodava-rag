ANTHROPIC_API_KEY=your_key_here
ANTHROPIC_BASE_URL=https://api.anthropic.com

# GitHub — source of truth for corpus data (anjanpoonacha/thakk)
# Read-only corpus sync works without a token (repo is public)
# Write (feedback) requires a PAT with contents:write on anjanpoonacha/thakk
GITHUB_TOKEN=your_pat_here
GITHUB_REPO=anjanpoonacha/thakk
GITHUB_BRANCH=main
